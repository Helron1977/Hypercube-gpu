{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hypercube Manifest",
  "type": "object",
  "required": ["name", "version", "engine", "config"],
  "properties": {
    "name": { "type": "string", "description": "Simulation friendly name" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "engine": {
      "type": "object",
      "required": ["name", "version", "faces", "rules", "requirements"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "requirements": {
          "type": "object",
          "required": ["ghostCells", "pingPong"],
          "properties": {
            "ghostCells": { "type": "integer", "minimum": 0, "maximum": 4 },
            "pingPong": { "type": "boolean" }
          }
        },
        "faces": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": "object",
            "required": ["name", "type", "isSynchronized"],
            "properties": {
              "name": { "type": "string" },
              "type": { "enum": ["scalar", "vector", "population", "macro", "field", "mask"] },
              "isSynchronized": { "type": "boolean" },
              "isPingPong": { "type": "boolean" },
              "defaultValue": { "type": "number" }
            }
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "source"],
            "properties": {
              "type": { "type": "string", "description": "The matching rule name in WGSL" },
              "source": { "type": "string", "description": "Path to WGSL file or raw string" },
              "params": { "type": "object" },
              "faces": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "config": {
      "type": "object",
      "required": ["dimensions", "chunks", "boundaries", "engine", "params"],
      "properties": {
        "dimensions": {
          "type": "object",
          "required": ["nx", "ny", "nz"],
          "properties": {
            "nx": { "type": "integer" },
            "ny": { "type": "integer" },
            "nz": { "type": "integer" }
          }
        },
        "chunks": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "integer" },
            "y": { "type": "integer" },
            "z": { "type": "integer" }
          }
        },
        "boundaries": { "type": "object" },
        "params": { "type": "object" },
        "engine": { "type": "string" }
      }
    }
  }
}
