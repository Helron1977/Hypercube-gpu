# src/

# Infrastructure & Tooling
vite.config.ts
vitest.config.ts
tsconfig.json
package-lock.json

# Test Suite & Documentation
tests/
scripts/
samples/
schemas/
# docs/ (Optionally excluded, but often useful for developers installing the package)
# docs/
