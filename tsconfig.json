{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },
    "types": ["@webgpu/types", "vitest/globals", "vite/client"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "noEmit": true
  },
  "include": ["src/**/*", "tests/**/*", "scripts/**/*", "env.d.ts"],
  "exclude": ["tests/renders/tensor-cp/assets/**/*"]
}
